[
  {
    "name": "theme_info",
    "theme_name": "MATGER",
    "theme_author": "Eslam Sharif",
    "theme_version": "1.0.0",
    "theme_documentation_url": "https://github.com/eslamsharif/d",
    "theme_support_url": "https://github.com/eslamsharif/d/issues"
  },
  {
    "name": "Brand",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon"
      },
      {
        "type": "text",
        "id": "logo_text",
        "label": "Logo text",
        "default": "MATGER"
      },
      {
        "type": "select",
        "id": "text_direction",
        "label": "Text direction",
        "default": "rtl",
        "options": [
          { "value": "rtl", "label": "RTL" },
          { "value": "ltr", "label": "LTR" }
        ]
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      { "type": "color", "id": "color_accent", "label": "Accent", "default": "#0071e3" },
      { "type": "color", "id": "color_background", "label": "Background", "default": "#ffffff" },
      { "type": "color", "id": "color_text", "label": "Text", "default": "#1d1d1f" },
      { "type": "color", "id": "color_muted", "label": "Muted text", "default": "#6e6e73" },
      { "type": "color", "id": "color_line", "label": "Lines", "default": "#e8e8ed" },
      { "type": "color", "id": "color_surface", "label": "Surface", "default": "#f5f5f7" },
      { "type": "color", "id": "color_surface_2", "label": "Secondary surface", "default": "#fbfbfd" }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "min": 1100,
        "max": 1500,
        "step": 20,
        "unit": "px",
        "label": "Page width",
        "default": 1200
      },
      {
        "type": "range",
        "id": "radius",
        "min": 10,
        "max": 32,
        "step": 2,
        "unit": "px",
        "label": "Corner radius",
        "default": 24
      },
      {
        "type": "checkbox",
        "id": "show_ratings",
        "label": "Show ratings",
        "default": true
      }
    ]
  }
]
