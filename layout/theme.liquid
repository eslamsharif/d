<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code | default: 'ar' }}" dir="{{ settings.text_direction }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_background }}">
    <link rel="canonical" href="{{ canonical_url }}">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} - {{ current_tags | join: ', ' }}{% endif -%}
      {%- if current_page != 1 %} - Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} - {{ shop.name }}{% endunless -%}
    </title>

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    {{ content_for_header }}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@300;400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
      :root {
        --accent: {{ settings.color_accent }};
        --accent-soft: {{ settings.color_accent | color_modify: 'alpha', 0.1 }};
        --bg: {{ settings.color_background }};
        --text: {{ settings.color_text }};
        --muted: {{ settings.color_muted }};
        --line: {{ settings.color_line }};
        --surface: {{ settings.color_surface }};
        --surface-2: {{ settings.color_surface_2 }};
        --page: {{ settings.page_width }}px;
        --radius: {{ settings.radius }}px;
      }
    </style>

    {{ 'theme.css' | asset_url | stylesheet_tag }}
    <script>document.documentElement.className = document.documentElement.className.replace('no-js', 'js');</script>
  </head>

  <body>
    <a class="skip-link" href="#MainContent">تخطى إلى المحتوى</a>
    {% section 'header' %}

    <main id="MainContent" role="main">
      {{ content_for_layout }}
    </main>

    {% section 'footer' %}

    <script>
      window.MATGER = {
        routes: {
          cart: {{ routes.cart_url | json }},
          cartAdd: {{ routes.cart_add_url | json }},
          cartChange: {{ routes.cart_change_url | json }}
        }
      };
    </script>
    {{ 'theme.js' | asset_url | script_tag }}
  </body>
</html>
