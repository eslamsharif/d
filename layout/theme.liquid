<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_background }}">

    <link rel="canonical" href="{{ canonical_url }}">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; {{ current_tags | join: ', ' }}{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    {{ content_for_header }}

    <style>
      :root {
        --color-background: {{ settings.color_background }};
        --color-foreground: {{ settings.color_foreground }};
        --color-muted: {{ settings.color_muted }};
        --color-surface: {{ settings.color_surface }};
        --color-border: {{ settings.color_border }};
        --color-accent: {{ settings.color_accent }};
        --page-width: {{ settings.page_width }}px;
        --radius-small: 8px;
        --radius-medium: 16px;
        --radius-large: 28px;
        --font-body: {{ settings.body_font.family }}, {{ settings.body_font.fallback_families }};
        --font-heading: {{ settings.heading_font.family }}, {{ settings.heading_font.fallback_families }};
      }
    </style>

    {{ settings.body_font | font_face: font_display: 'swap' }}
    {{ settings.heading_font | font_face: font_display: 'swap' }}
    {{ 'base.css' | asset_url | stylesheet_tag }}
    <script>document.documentElement.className = document.documentElement.className.replace('no-js', 'js');</script>
  </head>

  <body>
    <a class="skip-link" href="#MainContent">Skip to content</a>
    {% section 'header' %}

    <main id="MainContent" class="main-content" role="main">
      {{ content_for_layout }}
    </main>

    {% section 'footer' %}

    <script>
      window.ShopCo = {
        moneyFormat: {{ shop.money_format | json }},
        routes: {
          cart: {{ routes.cart_url | json }},
          cartAdd: {{ routes.cart_add_url | json }},
          cartChange: {{ routes.cart_change_url | json }}
        }
      };
    </script>
    {{ 'theme.js' | asset_url | script_tag }}
  </body>
</html>
