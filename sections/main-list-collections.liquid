<section class="collections-page">
  <div class="page-width">
    <div class="section-heading section-heading--center">
      <h1>Collections</h1>
    </div>

    <div class="collection-card-grid">
      {%- for collection in collections -%}
        {%- unless collection.handle == 'frontpage' -%}
          <a class="collection-card" href="{{ collection.url }}">
            {%- if collection.image -%}
              {{ collection.image | image_url: width: 700 | image_tag: loading: 'lazy', widths: '320, 480, 700', alt: collection.title | escape }}
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
            <span>{{ collection.title }}</span>
          </a>
        {%- endunless -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "List collections",
  "settings": []
}
{% endschema %}
