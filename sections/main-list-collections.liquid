<section class="m-list-collections">
  <div class="m-container">
    <div class="m-page-head">
      <div>
        <div class="m-eyebrow">{{ section.settings.eyebrow }}</div>
        <h1>{{ 'collections.general.title' | t }}</h1>
      </div>
    </div>

    <div class="m-grid m-grid--collections">
      {% for collection in collections %}
        {% unless collection.handle == 'frontpage' %}
          <a class="m-collection-card" href="{{ collection.url }}">
            <span class="m-collection-card__image">
              {% if collection.featured_image %}
                {{ collection.featured_image | image_url: width: 720 | image_tag: loading: 'lazy', sizes: '(min-width: 990px) 25vw, 50vw', widths: '240, 420, 720', alt: collection.featured_image.alt | escape }}
              {% else %}
                <span class="m-art m-art--tablet"><span></span></span>
              {% endif %}
            </span>
            <span class="m-collection-card__body">
              <strong>{{ collection.title }}</strong>
              <em>{{ 'collections.general.product_count' | t: count: collection.products_count }}</em>
            </span>
          </a>
        {% endunless %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main list collections",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Explore"
    }
  ]
}
{% endschema %}
