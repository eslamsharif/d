<header class="m-header">
  {%- if section.settings.promo_text != blank -%}
    <div class="m-promo">
      <div class="m-promo-inner">
        {% render 'icon', icon: 'sparkle', class: 'icon icon--tiny' %}
        <span>{{ section.settings.promo_text }}</span>
        {%- if section.settings.promo_link != blank -%}
          <a href="{{ section.settings.promo_link }}">{{ section.settings.promo_link_label }}</a>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  <nav class="m-nav" aria-label="Primary navigation">
    <button class="m-icon-btn m-menu-btn" type="button" aria-label="{{ 'general.menu' | t }}" aria-expanded="false" data-menu-toggle>
      {% render 'icon', icon: 'menu' %}
    </button>

    <a class="m-brand" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
      <span class="m-brand-mark" aria-hidden="true">M</span>
      <span class="m-brand-word">{{ settings.logo_text | default: 'MATGER' }}</span>
    </a>

    <ul class="m-nav-links">
      <li><a href="{{ routes.root_url }}" class="{% if request.page_type == 'index' %}is-active{% endif %}">الرئيسية</a></li>
      {%- if section.settings.menu != blank and section.settings.menu.links.size > 0 -%}
        {%- for link in section.settings.menu.links -%}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {%- endfor -%}
      {%- else -%}
        {%- for collection in collections limit: 7 -%}
          {%- unless collection.handle == 'frontpage' -%}
            <li><a href="{{ collection.url }}">{{ collection.title }}</a></li>
          {%- endunless -%}
        {%- endfor -%}
      {%- endif -%}
    </ul>

    <div class="m-nav-tools">
      <button class="m-icon-btn" type="button" aria-label="{{ 'general.search.label' | t }}" data-search-toggle>
        {% render 'icon', icon: 'search' %}
      </button>
      {%- if shop.customer_accounts_enabled -%}
        <a class="m-icon-btn" href="{{ routes.account_url }}" aria-label="{{ 'general.account' | t }}">
          {% render 'icon', icon: 'user' %}
        </a>
      {%- endif -%}
      <a class="m-icon-btn" href="{{ routes.cart_url }}" aria-label="{{ 'general.cart' | t }}" data-cart-link>
        {% render 'icon', icon: 'bag' %}
        {%- if cart.item_count > 0 -%}<span class="m-cart-dot" data-cart-count>{{ cart.item_count }}</span>{%- endif -%}
      </a>
    </div>

    <form action="{{ routes.search_url }}" method="get" class="m-search-strip" role="search" data-search-strip hidden>
      {% render 'icon', icon: 'search' %}
      <input type="hidden" name="type" value="product">
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'general.search_placeholder' | t }}" aria-label="{{ 'general.search.label' | t }}">
      <button class="m-icon-btn" type="button" aria-label="إغلاق البحث" data-search-toggle>{% render 'icon', icon: 'close' %}</button>
    </form>
  </nav>

  <div class="m-mobile-menu" data-mobile-menu hidden>
    <div class="m-mobile-panel">
      <button class="m-icon-btn m-mobile-close" type="button" aria-label="إغلاق" data-menu-close>{% render 'icon', icon: 'close' %}</button>
      <a href="{{ routes.root_url }}">الرئيسية</a>
      {%- if section.settings.menu != blank -%}
        {%- for link in section.settings.menu.links -%}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {%- endfor -%}
      {%- else -%}
        {%- for collection in collections limit: 8 -%}
          {%- unless collection.handle == 'frontpage' -%}<a href="{{ collection.url }}">{{ collection.title }}</a>{%- endunless -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "link_list", "id": "menu", "label": "Menu", "default": "main-menu" },
    { "type": "text", "id": "promo_text", "label": "Promo text", "default": "شحن مجاني للطلبات فوق 3000 ج.م" },
    { "type": "text", "id": "promo_link_label", "label": "Promo link label", "default": "تسوق الآن" },
    { "type": "url", "id": "promo_link", "label": "Promo link" }
  ]
}
{% endschema %}
