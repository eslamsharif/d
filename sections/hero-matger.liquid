<section class="m-hero">
  <div class="m-hero-inner">
    <div>
      <div class="m-eyebrow">{{ section.settings.eyebrow }}</div>
      <h1 class="m-hero-title">{{ section.settings.heading }} <span class="m-hero-grad">{{ section.settings.highlight }}</span></h1>
      <p class="m-hero-sub">{{ section.settings.text }}</p>
      <div class="m-hero-cta">
        <a class="m-btn m-btn-pri" href="{{ section.settings.primary_link | default: routes.collections_url }}">{{ section.settings.primary_label }} {% render 'icon', icon: 'arrow', class: 'icon icon--small' %}</a>
        <a class="m-btn m-btn-ghost" href="{{ section.settings.secondary_link | default: routes.collections_url }}">{{ section.settings.secondary_label }}</a>
      </div>
      <div class="m-hero-meta">
        <span>{{ section.settings.meta_1 }}</span>
        <span>{{ section.settings.meta_2 }}</span>
      </div>
    </div>

    <div class="m-hero-visual" aria-hidden="true">
      <div class="m-orbit"></div>
      <div class="m-device"></div>
      <div class="m-floating-chip one">{% render 'icon', icon: 'sparkle', class: 'icon icon--small' %} {{ section.settings.chip_1 }}</div>
      <div class="m-floating-chip two">{% render 'icon', icon: 'shield', class: 'icon icon--small' %} {{ section.settings.chip_2 }}</div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MATGER hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "جديد" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "هاتف Pro 16." },
    { "type": "text", "id": "highlight", "label": "Gradient highlight", "default": "مصنوع للمحترفين." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "شريحة Pro جديدة. كاميرا تتفوق على نفسها. تصميم تيتانيوم وتجربة تسوق مصممة للتكنولوجيا." },
    { "type": "text", "id": "primary_label", "label": "Primary label", "default": "اطلب الآن" },
    { "type": "url", "id": "primary_link", "label": "Primary link" },
    { "type": "text", "id": "secondary_label", "label": "Secondary label", "default": "اعرف المزيد" },
    { "type": "url", "id": "secondary_link", "label": "Secondary link" },
    { "type": "text", "id": "meta_1", "label": "Meta 1", "default": "يبدأ من 64,999 ج.م" },
    { "type": "text", "id": "meta_2", "label": "Meta 2", "default": "تقسيط حتى 12 شهر" },
    { "type": "text", "id": "chip_1", "label": "Chip 1", "default": "Pro Chip" },
    { "type": "text", "id": "chip_2", "label": "Chip 2", "default": "حماية وضمان" }
  ],
  "presets": [{ "name": "MATGER hero" }]
}
{% endschema %}
