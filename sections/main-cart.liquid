<section class="cart-page">
  <div class="page-width">
    <h1>{{ 'cart.general.title' | t }}</h1>

    {%- if cart.item_count > 0 -%}
      <form action="{{ routes.cart_url }}" method="post" class="cart-page__grid">
        <div class="cart-items">
          {%- for item in cart.items -%}
            <article class="cart-item">
              <a class="cart-item__media" href="{{ item.url }}">
                {%- if item.image -%}
                  {{ item.image | image_url: width: 220 | image_tag: loading: 'lazy', widths: '120, 180, 220', alt: item.image.alt | escape }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </a>

              <div class="cart-item__details">
                <h2><a href="{{ item.url }}">{{ item.product.title }}</a></h2>
                {%- unless item.product.has_only_default_variant -%}
                  <p>{{ item.variant.title }}</p>
                {%- endunless -%}
                <a class="cart-item__remove" href="{{ item.url_to_remove }}">{{ 'cart.general.remove' | t }}</a>
              </div>

              <label class="quantity-control cart-item__quantity" for="Updates-{{ forloop.index }}">
                <button type="button" data-quantity-minus aria-label="Decrease quantity">{% render 'icon', icon: 'minus' %}</button>
                <input id="Updates-{{ forloop.index }}" type="number" name="updates[]" value="{{ item.quantity }}" min="0">
                <button type="button" data-quantity-plus aria-label="Increase quantity">{% render 'icon', icon: 'plus' %}</button>
              </label>

              <div class="cart-item__price">{{ item.final_line_price | money }}</div>
            </article>
          {%- endfor -%}
        </div>

        <aside class="cart-summary">
          <h2>Order Summary</h2>
          <div class="cart-summary__row">
            <span>{{ 'cart.general.subtotal' | t }}</span>
            <strong>{{ cart.total_price | money }}</strong>
          </div>
          <p>Taxes and shipping calculated at checkout.</p>
          <button class="button button--secondary" type="submit" name="update">Update Cart</button>
          <button class="button button--primary" type="submit" name="checkout">{{ 'cart.general.checkout' | t }}</button>
        </aside>
      </form>
    {%- else -%}
      <div class="empty-state">
        <h2>{{ 'cart.general.empty' | t }}</h2>
        <a class="button button--primary" href="{{ routes.collections_url }}">Continue Shopping</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Main cart",
  "settings": []
}
{% endschema %}
