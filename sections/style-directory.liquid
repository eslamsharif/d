<section class="section-block style-directory">
  <div class="page-width">
    <div class="style-directory__shell">
      <div class="section-heading section-heading--center">
        <h2>{{ section.settings.heading }}</h2>
      </div>

      <div class="style-directory__grid">
        {%- for block in section.blocks -%}
          <a class="style-card style-card--{{ forloop.index }}" href="{{ block.settings.link | default: routes.collections_url }}" {{ block.shopify_attributes }}>
            <span>{{ block.settings.heading }}</span>
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 700
                | image_tag: loading: 'lazy', widths: '320, 480, 700', alt: block.settings.heading
              }}
            {%- endif -%}
          </a>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Style directory",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Browse by Dress Style"
    }
  ],
  "blocks": [
    {
      "type": "style",
      "name": "Style",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Casual"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Style directory",
      "blocks": [
        { "type": "style", "settings": { "heading": "Casual" } },
        { "type": "style", "settings": { "heading": "Formal" } },
        { "type": "style", "settings": { "heading": "Party" } },
        { "type": "style", "settings": { "heading": "Gym" } }
      ]
    }
  ]
}
{% endschema %}
