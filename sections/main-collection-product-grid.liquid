<section class="collection-page">
  <div class="page-width">
    <header class="collection-hero">
      <div>
        <p class="breadcrumbs"><a href="{{ routes.root_url }}">Home</a> / {{ collection.title }}</p>
        <h1>{{ collection.title }}</h1>
        {%- if collection.description != blank -%}
          <div class="rte">{{ collection.description }}</div>
        {%- endif -%}
      </div>

      <form class="collection-sort" method="get">
        <label for="SortBy-{{ section.id }}">Sort by</label>
        <select name="sort_by" id="SortBy-{{ section.id }}" onchange="this.form.submit()">
          {%- for option in collection.sort_options -%}
            <option value="{{ option.value }}" {% if option.value == collection.sort_by %}selected{% endif %}>{{ option.name }}</option>
          {%- endfor -%}
        </select>
      </form>
    </header>

    <div class="collection-layout">
      {%- if section.settings.show_tags and collection.all_tags.size > 0 -%}
        <aside class="collection-filters">
          <h2>Filters</h2>
          <a class="{% unless current_tags %}is-active{% endunless %}" href="{{ collection.url }}">All</a>
          {%- for tag in collection.all_tags -%}
            <a class="{% if current_tags contains tag %}is-active{% endif %}" href="{{ collection.url }}/{{ tag | handle }}">
              {{ tag }}
            </a>
          {%- endfor -%}
        </aside>
      {%- endif -%}

      <div class="collection-products">
        {%- paginate collection.products by section.settings.products_per_page -%}
          <div class="product-grid product-grid--3">
            {%- for product in collection.products -%}
              {% render 'product-card', product_card_product: product %}
            {%- else -%}
              <p>No products found in this collection.</p>
            {%- endfor -%}
          </div>

          {%- if paginate.pages > 1 -%}
            <nav class="pagination" aria-label="Pagination">
              {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}">Previous</a>{%- endif -%}
              <span>Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
              {%- if paginate.next -%}<a href="{{ paginate.next.url }}">Next</a>{%- endif -%}
            </nav>
          {%- endif -%}
        {%- endpaginate -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection product grid",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 24,
      "step": 4,
      "label": "Products per page",
      "default": 12
    },
    {
      "type": "checkbox",
      "id": "show_tags",
      "label": "Show tag filters",
      "default": true
    }
  ]
}
{% endschema %}
