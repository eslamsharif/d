<section class="section-block testimonials">
  <div class="page-width">
    <div class="section-heading">
      <h2>{{ section.settings.heading }}</h2>
    </div>

    <div class="testimonial-grid">
      {%- for block in section.blocks -%}
        <article class="testimonial-card" {{ block.shopify_attributes }}>
          {% render 'rating-stars', rating: 5 %}
          <h3>{{ block.settings.name }}</h3>
          <p>{{ block.settings.quote }}</p>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Happy Customers"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Sarah M."
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "I am blown away by the quality and style of the clothes I received. Every piece feels thoughtfully designed."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial", "settings": { "name": "Alex K." } },
        { "type": "testimonial", "settings": { "name": "James L." } }
      ]
    }
  ]
}
{% endschema %}
