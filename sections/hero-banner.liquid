<section class="hero-banner">
  <div class="page-width hero-banner__inner">
    <div class="hero-banner__copy">
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.text }}</p>
      {%- if section.settings.button_label != blank -%}
        <a class="button button--primary" href="{{ section.settings.button_link }}">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}

      <div class="hero-banner__stats">
        {%- for block in section.blocks -%}
          <div class="hero-banner__stat" {{ block.shopify_attributes }}>
            <strong>{{ block.settings.value }}</strong>
            <span>{{ block.settings.label }}</span>
          </div>
        {%- endfor -%}
      </div>
    </div>

    <div class="hero-banner__media">
      <span class="hero-banner__spark hero-banner__spark--large">&#10022;</span>
      <span class="hero-banner__spark hero-banner__spark--small">&#10022;</span>
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1200
          | image_tag:
            loading: 'eager',
            widths: '420, 700, 900, 1200',
            sizes: '(min-width: 990px) 50vw, 100vw',
            alt: section.settings.heading
        }}
      {%- else -%}
        <img src="{{ 'shopco-hero.png' | asset_url }}" alt="{{ section.settings.heading | escape }}" loading="eager">
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find Clothes That Matches Your Style"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Browse through our diverse range of meticulously crafted garments, designed to bring out your individuality and cater to your sense of style."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "200+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "International Brands"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero banner",
      "blocks": [
        { "type": "stat", "settings": { "value": "200+", "label": "International Brands" } },
        { "type": "stat", "settings": { "value": "2,000+", "label": "High-Quality Products" } },
        { "type": "stat", "settings": { "value": "30,000+", "label": "Happy Customers" } }
      ]
    }
  ]
}
{% endschema %}
