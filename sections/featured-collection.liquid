<section class="section-block featured-collection">
  <div class="page-width">
    <div class="section-heading section-heading--center">
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p>{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="product-grid product-grid--{{ section.settings.columns }}">
      {%- liquid
        assign collection = section.settings.collection
        assign products_to_show = section.settings.products_to_show
      -%}

      {%- if collection != blank and collection.products_count > 0 -%}
        {%- for product in collection.products limit: products_to_show -%}
          {% render 'product-card', product_card_product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- for index in (1..4) -%}
          {% render 'product-card' %}
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.button_label != blank -%}
      <div class="section-actions">
        <a class="button button--secondary" href="{{ collection.url | default: routes.collections_url }}">
          {{ section.settings.button_label }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "New Arrivals"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 12,
      "step": 1,
      "label": "Products to show",
      "default": 4
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns on desktop",
      "default": "4",
      "options": [
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ]
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "View All"
    }
  ],
  "presets": [
    {
      "name": "Featured collection"
    }
  ]
}
{% endschema %}
