<footer class="m-footer">
  <div class="m-footer-grid">
    <div>
      <a class="m-brand" href="{{ routes.root_url }}">
        <span class="m-brand-mark" aria-hidden="true">M</span>
        <span class="m-brand-word">{{ settings.logo_text | default: 'MATGER' }}</span>
      </a>
      <p>{{ section.settings.text }}</p>
    </div>

    {%- for block in section.blocks -%}
      <div class="m-footer-links" {{ block.shopify_attributes }}>
        <h2>{{ block.settings.heading }}</h2>
        {%- if block.settings.menu != blank -%}
          {%- for link in block.settings.menu.links -%}<a href="{{ link.url }}">{{ link.title }}</a>{%- endfor -%}
        {%- else -%}
          <a href="{{ routes.collections_url }}">المنتجات</a>
          <a href="{{ routes.search_url }}">البحث</a>
          <a href="{{ routes.cart_url }}">السلة</a>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
  <div class="m-footer-bottom">
    <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. جميع الحقوق محفوظة.</span>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "textarea", "id": "text", "label": "Text", "default": "MATGER متجر تقني بتجربة سلسة للهواتف والسماعات والساعات والملحقات الذكية." }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Link list",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "روابط" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "link_list", "settings": { "heading": "التسوق" } },
      { "type": "link_list", "settings": { "heading": "الدعم" } },
      { "type": "link_list", "settings": { "heading": "الشركة" } }
    ]
  }
}
{% endschema %}
