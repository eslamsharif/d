<section class="m-page">
  <div class="m-container m-narrow">
    <div class="m-page-head m-page-head--center">
      <div>
        <div class="m-eyebrow">{{ section.settings.eyebrow }}</div>
        <h1>{{ page.title }}</h1>
      </div>
    </div>
    <div class="m-page-content rte">
      {{ page.content }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main page",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "MATGER"
    }
  ]
}
{% endschema %}
