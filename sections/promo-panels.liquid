<section class="section-block promo-panels">
  <div class="page-width">
    <div class="section-heading section-heading--center">
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.text != blank -%}
        <p>{{ section.settings.text }}</p>
      {%- endif -%}
    </div>

    <div class="promo-panels__grid">
      {%- for block in section.blocks -%}
        <a class="promo-panel promo-panel--{{ forloop.index }}" href="{{ block.settings.link | default: routes.collections_url }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 1000
              | image_tag: loading: 'lazy', widths: '420, 640, 820, 1000', alt: block.settings.heading
            }}
          {%- endif -%}
          <div class="promo-panel__content">
            <span>{{ block.settings.eyebrow }}</span>
            <h3>{{ block.settings.heading }}</h3>
            <p>{{ block.settings.text }}</p>
            <strong>
              {{ block.settings.link_label }}
              {% render 'icon', icon: 'arrow-right', class: 'icon icon--small' %}
            </strong>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Promo panels",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop The Moment"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Editorial collections designed around the way people actually dress."
    }
  ],
  "blocks": [
    {
      "type": "panel",
      "name": "Panel",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow",
          "default": "New Season"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Clean layers for every day"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Soft neutrals, relaxed silhouettes, and simple styling."
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "Explore"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Promo panels",
      "blocks": [
        { "type": "panel", "settings": { "eyebrow": "New Season", "heading": "Clean layers for every day", "text": "Soft neutrals, relaxed silhouettes, and easy styling." } },
        { "type": "panel", "settings": { "eyebrow": "Weekend", "heading": "Casual essentials", "text": "T-shirts, denim, and outerwear with a sharper finish." } },
        { "type": "panel", "settings": { "eyebrow": "Occasion", "heading": "Dress smarter", "text": "Tailored pieces for sharper days and nights out." } }
      ]
    }
  ]
}
{% endschema %}
