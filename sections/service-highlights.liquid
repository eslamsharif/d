<section class="service-highlights service-highlights--{{ section.settings.style }}">
  <div class="page-width">
    <div class="service-highlights__grid">
      {%- for block in section.blocks -%}
        <div class="service-highlight" {{ block.shopify_attributes }}>
          <span class="service-highlight__icon">
            {% render 'icon', icon: block.settings.icon, class: 'icon' %}
          </span>
          <div>
            <h2>{{ block.settings.heading }}</h2>
            <p>{{ block.settings.text }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Service highlights",
  "settings": [
    {
      "type": "select",
      "id": "style",
      "label": "Style",
      "default": "band",
      "options": [
        { "value": "band", "label": "Band" },
        { "value": "compact", "label": "Compact" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "highlight",
      "name": "Highlight",
      "limit": 4,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "truck",
          "options": [
            { "value": "truck", "label": "Truck" },
            { "value": "refresh", "label": "Refresh" },
            { "value": "shield", "label": "Shield" },
            { "value": "star", "label": "Star" },
            { "value": "check", "label": "Check" }
          ]
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Free Shipping"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "On all orders over $75"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Service highlights",
      "blocks": [
        { "type": "highlight", "settings": { "icon": "truck", "heading": "Free Shipping", "text": "On all orders over $75" } },
        { "type": "highlight", "settings": { "icon": "refresh", "heading": "Easy Returns", "text": "30 day return window" } },
        { "type": "highlight", "settings": { "icon": "shield", "heading": "Secure Checkout", "text": "Encrypted payment flow" } },
        { "type": "highlight", "settings": { "icon": "star", "heading": "Premium Quality", "text": "Curated daily essentials" } }
      ]
    }
  ]
}
{% endschema %}
