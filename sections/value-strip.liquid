<section class="m-section">
  <div class="m-values">
    {%- for block in section.blocks -%}
      <div class="m-value" {{ block.shopify_attributes }}>
        <span class="m-value-icon">{% render 'icon', icon: block.settings.icon, class: 'icon icon--small' %}</span>
        <div>
          <h3>{{ block.settings.heading }}</h3>
          <p>{{ block.settings.text }}</p>
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Value strip",
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "limit": 4,
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "default": "truck", "options": [
          { "value": "truck", "label": "Truck" },
          { "value": "shield", "label": "Shield" },
          { "value": "refresh", "label": "Refresh" },
          { "value": "check", "label": "Check" }
        ] },
        { "type": "text", "id": "heading", "label": "Heading", "default": "شحن سريع" },
        { "type": "text", "id": "text", "label": "Text", "default": "توصيل وتتبع للطلبات" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Value strip",
      "blocks": [
        { "type": "value", "settings": { "icon": "truck", "heading": "شحن سريع", "text": "توصيل وتتبع للطلبات" } },
        { "type": "value", "settings": { "icon": "refresh", "heading": "إرجاع سهل", "text": "خلال 30 يومًا" } },
        { "type": "value", "settings": { "icon": "shield", "heading": "دفع آمن", "text": "تشفير كامل للدفع" } },
        { "type": "value", "settings": { "icon": "check", "heading": "ضمان حقيقي", "text": "منتجات موثوقة" } }
      ]
    }
  ]
}
{% endschema %}
