{% liquid
  assign current_variant = product.selected_or_first_available_variant
  assign media_count = product.media.size
%}

<section class="m-product">
  <div class="m-container">
    <nav class="m-breadcrumb" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">{{ 'general.home' | t }}</a>
      <span>/</span>
      {% if collection %}
        <a href="{{ collection.url }}">{{ collection.title }}</a>
        <span>/</span>
      {% endif %}
      <span>{{ product.title }}</span>
    </nav>

    <div class="m-product-layout">
      <div class="m-product-media" data-product-gallery>
        <div class="m-product-stage" data-gallery-stage>
          {% if current_variant.featured_media %}
            {{ current_variant.featured_media | image_url: width: 1200 | image_tag: loading: 'eager', sizes: '(min-width: 990px) 52vw, 100vw', widths: '480, 720, 960, 1200', alt: current_variant.featured_media.alt | escape }}
          {% elsif product.featured_media %}
            {{ product.featured_media | image_url: width: 1200 | image_tag: loading: 'eager', sizes: '(min-width: 990px) 52vw, 100vw', widths: '480, 720, 960, 1200', alt: product.featured_media.alt | escape }}
          {% else %}
            {% render 'product-art', product: product %}
          {% endif %}
        </div>

        {% if media_count > 1 %}
          <div class="m-product-thumbs" role="list">
            {% for media in product.media limit: 6 %}
            <button class="m-thumb{% if forloop.first %} is-active{% endif %}" type="button" data-gallery-thumb="{{ media | image_url: width: 1200 }}" aria-label="{{ media.alt | default: product.title | escape }}">
                {{ media.preview_image | image_url: width: 160 | image_tag: loading: 'lazy', sizes: '76px', widths: '80, 120, 160', alt: media.alt | escape }}
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="m-product-info">
        <div class="m-eyebrow">{{ product.vendor | default: shop.name }}</div>
        <h1>{{ product.title }}</h1>

        <div class="m-product-rating" aria-label="{{ 'products.product.rating' | t }}">
          {% for index in (1..5) %}
            {% render 'icon', icon: 'star' %}
          {% endfor %}
          <span>4.8</span>
        </div>

        <div class="m-product-price" data-product-price>
          {% render 'price', product: product, variant: current_variant %}
        </div>

        {% if product.description != blank %}
          <div class="m-product-copy">
            {{ product.description | strip_html | truncatewords: 42 }}
          </div>
        {% else %}
          <div class="m-product-copy">{{ section.settings.fallback_description }}</div>
        {% endif %}

        {% form 'product', product, class: 'm-product-form', data-product-form: '' %}
          <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id>

          {% unless product.has_only_default_variant %}
            <div class="m-variant-groups" data-variant-picker>
              {% for option in product.options_with_values %}
                <fieldset class="m-variant-group">
                  <legend>{{ option.name }}</legend>
                  <div class="m-option-list">
                    {% for value in option.values %}
                      <label class="m-option">
                        <input
                          type="radio"
                          name="options[{{ option.name | escape }}]"
                          value="{{ value | escape }}"
                          {% if option.selected_value == value %}checked{% endif %}
                          data-option-position="{{ option.position }}"
                        >
                        <span>{{ value }}</span>
                      </label>
                    {% endfor %}
                  </div>
                </fieldset>
              {% endfor %}
            </div>
          {% endunless %}

          <script type="application/json" data-product-json>
            {{ product.variants | json }}
          </script>

          <div class="m-buy-row">
            <div class="m-qty" data-quantity>
              <button type="button" data-quantity-minus aria-label="{{ 'products.product.decrease_quantity' | t }}">{% render 'icon', icon: 'minus' %}</button>
              <input type="number" name="quantity" min="1" value="1" aria-label="{{ 'products.product.quantity' | t }}">
              <button type="button" data-quantity-plus aria-label="{{ 'products.product.increase_quantity' | t }}">{% render 'icon', icon: 'plus' %}</button>
            </div>

            <button
              class="m-button m-button--dark"
              type="submit"
              data-product-submit
              data-add-text="{{ 'products.product.add_to_cart' | t }}"
              data-sold-text="{{ 'products.product.sold_out' | t }}"
              {% unless current_variant.available %}disabled{% endunless %}
            >
              <span data-add-label>
                {% if current_variant.available %}
                  {{ 'products.product.add_to_cart' | t }}
                {% else %}
                  {{ 'products.product.sold_out' | t }}
                {% endif %}
              </span>
            </button>
          </div>
        {% endform %}

        <div class="m-assurance">
          <div>
            {% render 'icon', icon: 'truck' %}
            <span>{{ section.settings.shipping_text }}</span>
          </div>
          <div>
            {% render 'icon', icon: 'shield' %}
            <span>{{ section.settings.warranty_text }}</span>
          </div>
          <div>
            {% render 'icon', icon: 'refresh' %}
            <span>{{ section.settings.returns_text }}</span>
          </div>
        </div>
      </div>
    </div>

    {% if section.settings.show_details %}
      <div class="m-product-details">
        <div>
          <h2>{{ section.settings.details_heading }}</h2>
          <div class="rte">
            {% if product.description != blank %}
              {{ product.description }}
            {% else %}
              <p>{{ section.settings.fallback_description }}</p>
            {% endif %}
          </div>
        </div>
        <aside>
          <h3>{{ section.settings.specs_heading }}</h3>
          <ul>
            <li>{{ 'products.product.spec_brand' | t }}: {{ product.vendor | default: shop.name }}</li>
            <li>{{ 'products.product.spec_type' | t }}: {{ product.type | default: 'Tech' }}</li>
            <li>{{ 'products.product.spec_availability' | t }}: {% if current_variant.available %}{{ 'products.product.in_stock' | t }}{% else %}{{ 'products.product.sold_out' | t }}{% endif %}</li>
          </ul>
        </aside>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Main product",
  "settings": [
    {
      "type": "text",
      "id": "fallback_description",
      "label": "Fallback description",
      "default": "Premium tech essentials with refined materials, fast performance, and a smooth everyday experience."
    },
    {
      "type": "text",
      "id": "shipping_text",
      "label": "Shipping text",
      "default": "Free shipping on eligible orders"
    },
    {
      "type": "text",
      "id": "warranty_text",
      "label": "Warranty text",
      "default": "Official warranty and secure checkout"
    },
    {
      "type": "text",
      "id": "returns_text",
      "label": "Returns text",
      "default": "Easy returns within 14 days"
    },
    {
      "type": "checkbox",
      "id": "show_details",
      "label": "Show product details",
      "default": true
    },
    {
      "type": "text",
      "id": "details_heading",
      "label": "Details heading",
      "default": "Product details"
    },
    {
      "type": "text",
      "id": "specs_heading",
      "label": "Specs heading",
      "default": "Quick specs"
    }
  ]
}
{% endschema %}
