{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_form_id = 'product-form-' | append: section.id
-%}

<section class="product-page">
  <div class="page-width product-page__grid">
    <div class="product-gallery" data-product-gallery>
      <div class="product-gallery__main">
        {%- if product.media.size > 0 -%}
          {%- for media in product.media -%}
            <div class="product-gallery__slide{% if forloop.first %} is-active{% endif %}" data-gallery-slide="{{ forloop.index0 }}">
              {%- if media.media_type == 'image' -%}
                {{
                  media
                  | image_url: width: 1100
                  | image_tag:
                    loading: 'eager',
                    widths: '480, 720, 900, 1100',
                    sizes: '(min-width: 990px) 50vw, 100vw',
                    alt: media.alt | escape
                }}
              {%- else -%}
                {{ media | media_tag: image_size: '900x', autoplay: false, loop: false, controls: true }}
              {%- endif -%}
            </div>
          {%- endfor -%}
        {%- else -%}
          <div class="product-gallery__placeholder">{{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}</div>
        {%- endif -%}
      </div>

      {%- if product.media.size > 1 -%}
        <div class="product-gallery__thumbs">
          {%- for media in product.media -%}
            <button class="product-gallery__thumb{% if forloop.first %} is-active{% endif %}" type="button" data-gallery-thumb="{{ forloop.index0 }}" aria-label="View image {{ forloop.index }}">
              {%- if media.preview_image -%}
                {{ media.preview_image | image_url: width: 180 | image_tag: loading: 'lazy', widths: '90, 140, 180', alt: media.alt | escape }}
              {%- endif -%}
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <div class="product-info">
      <p class="breadcrumbs"><a href="{{ routes.root_url }}">Home</a> / {{ product.title }}</p>
      <h1>{{ product.title }}</h1>

      {%- if settings.show_rating -%}
        {%- liquid
          assign rating_value = product.metafields.reviews.rating.value.rating | default: 4.5
        -%}
        {% render 'rating-stars', rating: rating_value, show_text: true %}
      {%- endif -%}

      <div class="product-info__price" data-product-price>
        {% render 'price', product: product, use_variant: true %}
      </div>

      {%- if product.description != blank -%}
        <div class="product-info__description rte">{{ product.description }}</div>
      {%- endif -%}

      {%- form 'product', product, id: product_form_id, class: 'product-form' -%}
        <select name="id" class="product-form__variant-select" data-variant-select aria-label="{{ 'products.product.variant' | t }}">
          {%- for variant in product.variants -%}
            <option
              value="{{ variant.id }}"
              {% if variant == current_variant %}selected="selected"{% endif %}
              {% unless variant.available %}disabled{% endunless %}
            >
              {{ variant.title }} - {{ variant.price | money }}
            </option>
          {%- endfor -%}
        </select>

        {%- unless product.has_only_default_variant -%}
          <div class="product-options" data-product-options>
            {%- for option in product.options_with_values -%}
              <fieldset class="product-option">
                <legend>{{ option.name }}</legend>
                <div class="product-option__values">
                  {%- for value in option.values -%}
                    {%- assign input_id = section.id | append: '-' | append: option.position | append: '-' | append: forloop.index -%}
                    <input
                      type="radio"
                      id="{{ input_id }}"
                      name="option-{{ option.position }}"
                      value="{{ value | escape }}"
                      {% if option.selected_value == value %}checked{% endif %}
                      data-option-position="{{ option.position }}"
                    >
                    <label for="{{ input_id }}">{{ value }}</label>
                  {%- endfor -%}
                </div>
              </fieldset>
            {%- endfor -%}
          </div>
        {%- endunless -%}

        <div class="product-form__actions">
          <label class="quantity-control" for="Quantity-{{ section.id }}">
            <span class="visually-hidden">{{ 'products.product.quantity' | t }}</span>
            <button type="button" data-quantity-minus aria-label="Decrease quantity">{% render 'icon', icon: 'minus' %}</button>
            <input id="Quantity-{{ section.id }}" type="number" name="quantity" value="1" min="1">
            <button type="button" data-quantity-plus aria-label="Increase quantity">{% render 'icon', icon: 'plus' %}</button>
          </label>

          <button class="button button--primary product-form__submit" type="submit" {% unless current_variant.available %}disabled{% endunless %}>
            {%- if current_variant.available -%}
              {{ 'products.product.add_to_cart' | t }}
            {%- else -%}
              {{ 'products.product.sold_out' | t }}
            {%- endif -%}
          </button>
        </div>

        {{ form | payment_button }}

        <script type="application/json" data-product-json>
          {{ product.variants | json }}
        </script>
      {%- endform -%}

      <div class="product-info__meta">
        {%- if product.vendor != blank -%}<span>Brand: {{ product.vendor }}</span>{%- endif -%}
        {%- if product.type != blank -%}<span>Type: {{ product.type }}</span>{%- endif -%}
        {%- if product.tags.size > 0 -%}<span>Tags: {{ product.tags | join: ', ' }}</span>{%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main product",
  "settings": []
}
{% endschema %}
