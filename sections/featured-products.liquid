<section class="m-section">
  <div class="m-section-head">
    <div>
      {%- if section.settings.eyebrow != blank -%}<div class="m-eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
      <h2 class="m-section-title">{{ section.settings.heading }}</h2>
      {%- if section.settings.text != blank -%}<p class="m-section-text">{{ section.settings.text }}</p>{%- endif -%}
    </div>
    {%- if section.settings.collection != blank -%}
      <a class="m-link" href="{{ section.settings.collection.url }}">عرض الكل {% render 'icon', icon: 'chevron', class: 'icon icon--small' %}</a>
    {%- endif -%}
  </div>

  <div class="m-grid">
    {%- assign selected_collection = section.settings.collection -%}
    {%- if selected_collection != blank and selected_collection.products_count > 0 -%}
      {%- for product in selected_collection.products limit: section.settings.limit -%}
        {% render 'product-card', product_card_product: product %}
      {%- endfor -%}
    {%- else -%}
      {%- for product in collections.all.products limit: section.settings.limit -%}
        {% render 'product-card', product_card_product: product %}
      {%- else -%}
        {%- for index in (1..4) -%}
          {% render 'product-card' %}
        {%- endfor -%}
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "مختار لك" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "الأكثر مبيعًا" },
    { "type": "text", "id": "text", "label": "Text", "default": "منتجات تقنية بتجربة عرض قريبة من تصميم MATGER." },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "limit", "min": 4, "max": 12, "step": 1, "label": "Products", "default": 8 }
  ],
  "presets": [{ "name": "Featured products" }]
}
{% endschema %}
