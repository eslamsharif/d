{%- liquid
  assign card_product = product_card_product | default: product
  assign selected_variant = card_product.selected_or_first_available_variant
  assign rating_value = card_product.metafields.reviews.rating.value.rating | default: 4.8
  assign review_count = card_product.metafields.reviews.rating_count.value | default: 128
  assign fallback_type = 'products.product.tech' | t
-%}

<article class="m-card">
  <div class="m-card-media">
    <a href="{{ card_product.url | default: '#' }}" aria-label="{{ card_product.title | escape }}">
      {%- if card_product.featured_media -%}
        {{
          card_product.featured_media
          | image_url: width: 720
          | image_tag:
            loading: 'lazy',
            widths: '260, 420, 560, 720',
            sizes: '(min-width: 990px) 25vw, (min-width: 700px) 50vw, 100vw',
            class: 'm-card-img',
            alt: card_product.featured_media.alt | escape
        }}
      {%- else -%}
        {% render 'product-art', product: card_product %}
      {%- endif -%}
    </a>

    {%- if card_product.compare_at_price > card_product.price -%}
      <span class="m-badge m-badge-sale">{{ 'products.product.sale' | t }}</span>
    {%- elsif card_product.tags contains 'new' or card_product.tags contains 'New' -%}
      <span class="m-badge m-badge-new">{{ 'products.product.new' | t }}</span>
    {%- else -%}
      <span class="m-badge">{{ 'products.product.featured' | t }}</span>
    {%- endif -%}

    <a class="m-fav" href="{{ card_product.url | default: '#' }}" aria-label="{{ 'products.product.save' | t }}">
      {% render 'icon', icon: 'heart', class: 'icon icon--small' %}
    </a>

    {%- if card_product != blank and selected_variant.available -%}
      {%- form 'product', card_product, class: 'm-card-quick' -%}
        <input type="hidden" name="id" value="{{ selected_variant.id }}">
        <input type="hidden" name="quantity" value="1">
        <button
          type="submit"
          data-loading-label="{{ 'products.product.adding' | t }}"
          data-added-label="{{ 'products.product.added' | t }}"
        >
          {{ 'products.product.quick_add' | t }}
        </button>
      {%- endform -%}
    {%- endif -%}
  </div>

  <div class="m-card-body">
    <div class="m-card-cat">{{ card_product.type | default: card_product.vendor | default: fallback_type }}</div>
    <h3 class="m-card-name"><a href="{{ card_product.url | default: '#' }}">{{ card_product.title | default: 'هاتف Pro 16' }}</a></h3>

    {%- if settings.show_ratings -%}
      <div class="m-card-rate">
        {% render 'icon', icon: 'star', class: 'icon icon--tiny' %}
        <span>{{ rating_value }}</span>
        <span>({{ review_count }})</span>
      </div>
    {%- endif -%}

    <div class="m-card-foot">
      {%- if card_product != blank -%}
        {% render 'price', product: card_product %}
      {%- else -%}
        <span class="m-price"><span class="m-price-current">64,999 ج.م</span></span>
      {%- endif -%}

      <a class="m-card-open" href="{{ card_product.url | default: '#' }}" aria-label="{{ 'products.product.view' | t }}">
        {% render 'icon', icon: 'plus', class: 'icon icon--small' %}
      </a>
    </div>
  </div>
</article>
