{%- liquid
  assign icon_name = icon | default: 'arrow-right'
  assign icon_class = class | default: 'icon'
-%}

{%- case icon_name -%}
  {%- when 'search' -%}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path d="m21 21-4.35-4.35m2.35-5.15a7.5 7.5 0 1 1-15 0 7.5 7.5 0 0 1 15 0Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>
  {%- when 'cart' -%}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path d="M6.5 8.5h13l-1.2 8.3a2 2 0 0 1-2 1.7H8.8a2 2 0 0 1-2-1.7L5.4 4.5H3" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M9 21a.5.5 0 1 0 0-1 .5.5 0 0 0 0 1Zm8 0a.5.5 0 1 0 0-1 .5.5 0 0 0 0 1Z" fill="currentColor" stroke="currentColor"/>
    </svg>
  {%- when 'account' -%}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path d="M20 21a8 8 0 0 0-16 0m12-13a4 4 0 1 1-8 0 4 4 0 0 1 8 0Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>
  {%- when 'menu' -%}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path d="M4 7h16M4 12h16M4 17h16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>
  {%- when 'close' -%}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path d="m6 6 12 12M18 6 6 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>
  {%- when 'chevron-down' -%}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path d="m6 9 6 6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  {%- when 'arrow-right' -%}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path d="M5 12h14m-6-6 6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  {%- when 'plus' -%}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path d="M12 5v14M5 12h14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>
  {%- when 'minus' -%}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path d="M5 12h14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>
  {%- when 'star' -%}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path d="m12 2.6 2.9 5.9 6.5 1-4.7 4.5 1.1 6.4L12 17.4l-5.8 3 1.1-6.4-4.7-4.5 6.5-1L12 2.6Z" fill="currentColor"/>
    </svg>
  {%- when 'check' -%}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path d="m20 6-11 11-5-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  {%- when 'heart' -%}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path d="M20.8 4.6a5.4 5.4 0 0 0-7.6 0L12 5.8l-1.2-1.2a5.4 5.4 0 0 0-7.6 7.6L12 21l8.8-8.8a5.4 5.4 0 0 0 0-7.6Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  {%- when 'truck' -%}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path d="M3 6h12v10H3V6Zm12 4h3l3 3v3h-6v-6Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
      <path d="M7 19a2 2 0 1 0 0-4 2 2 0 0 0 0 4Zm10 0a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" fill="none" stroke="currentColor" stroke-width="2"/>
    </svg>
  {%- when 'refresh' -%}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path d="M20 7v5h-5M4 17v-5h5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M18.1 12A6.5 6.5 0 0 0 6.7 7.7L4 10m2 2a6.5 6.5 0 0 0 11.3 4.3L20 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  {%- when 'shield' -%}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path d="M12 3 20 6v6c0 5-3.4 7.8-8 9-4.6-1.2-8-4-8-9V6l8-3Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
      <path d="m9 12 2 2 4-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
{%- endcase -%}
