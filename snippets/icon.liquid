{%- liquid
  assign icon_name = icon | default: 'arrow'
  assign icon_class = class | default: 'icon'
-%}

{%- case icon_name -%}
  {%- when 'search' -%}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false"><path d="M11 4a7 7 0 1 1 0 14 7 7 0 0 1 0-14Zm9 16-4.3-4.3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
  {%- when 'bag' -%}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false"><path d="M6 8h12l-1 12H7L6 8Zm3 0V6a3 3 0 0 1 6 0v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
  {%- when 'user' -%}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false"><path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm-7 8a7 7 0 0 1 14 0" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
  {%- when 'heart' -%}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false"><path d="M12 20s-7-4.5-7-10a4 4 0 0 1 7-2.7A4 4 0 0 1 19 10c0 5.5-7 10-7 10Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
  {%- when 'menu' -%}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false"><path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
  {%- when 'close' -%}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false"><path d="M6 6l12 12M18 6 6 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
  {%- when 'chevron' -%}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false"><path d="m9 6 6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
  {%- when 'chevron-left' -%}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false"><path d="m15 6-6 6 6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
  {%- when 'plus' -%}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
  {%- when 'minus' -%}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false"><path d="M5 12h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
  {%- when 'arrow' -%}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false"><path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
  {%- when 'star' -%}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="m12 3 2.7 5.5 6 .9-4.4 4.3 1 6L12 17l-5.4 2.8 1-6L3.3 9.5l6-1L12 3Z" fill="currentColor"/></svg>
  {%- when 'check' -%}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false"><path d="m5 12 5 5L20 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
  {%- when 'truck' -%}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false"><path d="M3 7h11v9H3zM14 10h4l3 3v3h-7zM7 19a2 2 0 1 0 0-4 2 2 0 0 0 0 4Zm10 0a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
  {%- when 'shield' -%}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false"><path d="M12 3 4 6v6c0 5 3.4 8.4 8 9 4.6-.6 8-4 8-9V6l-8-3Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
  {%- when 'refresh' -%}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false"><path d="M3 12a9 9 0 0 1 15.5-6.3M21 4v5h-5M21 12a9 9 0 0 1-15.5 6.3M3 20v-5h5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
  {%- when 'sparkle' -%}
    <svg class="{{ icon_class }}" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false"><path d="M12 3v6M12 15v6M3 12h6M15 12h6M6 6l3 3M15 15l3 3M18 6l-3 3M9 15l-3 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
{%- endcase -%}
